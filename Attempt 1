<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Pulse — Feedback Tracker</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/react/18.2.0/umd/react.production.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/react-dom/18.2.0/umd/react-dom.production.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/babel-standalone/7.23.2/babel.min.js"></script>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=IBM+Plex+Mono:wght@400;500&family=Bricolage+Grotesque:wght@400;500;600&display=swap" rel="stylesheet" />

  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            serif:  ['Instrument Serif', 'Georgia', 'serif'],
            mono:   ['IBM Plex Mono', 'monospace'],
            sans:   ['Bricolage Grotesque', 'sans-serif'],
          }
        }
      }
    }
  </script>

  <style>
    :root {
      --bg:        #0d1117;
      --surface:   #161b22;
      --border:    #21262d;
      --border-hi: #30363d;
      --text:      #e6edf3;
      --muted:     #7d8590;
      --faint:     #21262d;

      --pos:  #39d353;  /* positive  — green */
      --neg:  #f85149;  /* negative  — red   */
      --neu:  #58a6ff;  /* neutral   — blue  */
    }

    * { box-sizing: border-box; }

    body {
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      font-family: 'Bricolage Grotesque', sans-serif;
    }

    /* Subtle grid texture */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(var(--border) 1px, transparent 1px),
        linear-gradient(90deg, var(--border) 1px, transparent 1px);
      background-size: 48px 48px;
      opacity: 0.35;
      pointer-events: none;
      z-index: 0;
    }

    #root { position: relative; z-index: 1; }

    /* ── Sentiment stripe on card left edge ── */
    .card-pos { border-left: 3px solid var(--pos); }
    .card-neg { border-left: 3px solid var(--neg); }
    .card-neu { border-left: 3px solid var(--neu); }

    /* ── Badges ── */
    .badge {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 10px;
      font-weight: 500;
      padding: 2px 8px;
      border-radius: 3px;
      letter-spacing: 0.03em;
      text-transform: uppercase;
    }

    .badge-pos { background: rgba(57,211,83,.12); color: var(--pos); border: 1px solid rgba(57,211,83,.25); }
    .badge-neg { background: rgba(248,81,73,.12); color: var(--neg); border: 1px solid rgba(248,81,73,.25); }
    .badge-neu { background: rgba(88,166,255,.12); color: var(--neu); border: 1px solid rgba(88,166,255,.25); }

    .badge-open       { background: rgba(125,133,144,.1); color: var(--muted); border: 1px solid rgba(125,133,144,.2); }
    .badge-inprogress { background: rgba(210,153,34,.12); color: #d2a22a;      border: 1px solid rgba(210,153,34,.25); }
    .badge-addressed  { background: rgba(57,211,83,.1);   color: #39d353;      border: 1px solid rgba(57,211,83,.2); }

    .badge-source   { background: rgba(125,133,144,.08); color: var(--muted); border: 1px solid var(--border-hi); }
    .badge-category { background: rgba(88,166,255,.08);  color: #58a6ff;      border: 1px solid rgba(88,166,255,.2); }

    /* ── Form controls ── */
    .ctrl {
      background: var(--surface);
      border: 1px solid var(--border-hi);
      color: var(--text);
      border-radius: 6px;
      font-family: 'Bricolage Grotesque', sans-serif;
      font-size: 14px;
      padding: 8px 12px;
      transition: border-color .15s, box-shadow .15s;
      width: 100%;
    }
    .ctrl::placeholder { color: var(--muted); }
    .ctrl:focus {
      outline: none;
      border-color: #58a6ff;
      box-shadow: 0 0 0 3px rgba(88,166,255,.12);
    }
    textarea.ctrl { resize: vertical; min-height: 88px; }

    /* ── Buttons ── */
    .btn-primary {
      background: #238636;
      color: #fff;
      border: 1px solid #2ea043;
      border-radius: 6px;
      font-family: 'Bricolage Grotesque', sans-serif;
      font-size: 13px;
      font-weight: 600;
      padding: 8px 18px;
      cursor: pointer;
      transition: background .15s, transform .1s;
    }
    .btn-primary:hover  { background: #2ea043; }
    .btn-primary:active { transform: scale(.97); }
    .btn-primary:disabled { opacity: .45; cursor: not-allowed; }

    .btn-ghost {
      background: transparent;
      color: var(--muted);
      border: 1px solid var(--border-hi);
      border-radius: 6px;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 11px;
      padding: 5px 10px;
      cursor: pointer;
      transition: color .15s, border-color .15s, background .15s;
    }
    .btn-ghost:hover { color: var(--neg); border-color: var(--neg); background: rgba(248,81,73,.06); }

    /* ── Animations ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(10px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .fade-up { animation: fadeUp .22s ease-out both; }

    @keyframes pulse {
      0%, 100% { opacity: .4; }
      50%       { opacity: .8; }
    }
    .skel { animation: pulse 1.4s ease-in-out infinite; background: var(--faint); border-radius: 4px; }

    /* ── Auth card ── */
    @keyframes authIn {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .auth-in { animation: authIn .28s ease-out; }

    /* ── Filter pills ── */
    .pill {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 11px;
      padding: 4px 12px;
      border-radius: 20px;
      border: 1px solid var(--border-hi);
      background: transparent;
      color: var(--muted);
      cursor: pointer;
      transition: all .15s;
    }
    .pill.active, .pill:hover {
      background: rgba(88,166,255,.1);
      border-color: rgba(88,166,255,.4);
      color: #58a6ff;
    }
    .pill.active { font-weight: 500; }

    /* scrollbar */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--border-hi); border-radius: 3px; }
  </style>
</head>
<body>
<div id="root"></div>

<script type="text/babel">
const { createClient } = supabase;
const sb = createClient(
  'https://uqbvpytbqvlubuekgcbz.supabase.co',
  'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InVxYnZweXRicXZsdWJ1ZWtnY2J6Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU0NDgwMzcsImV4cCI6MjA5MTAyNDAzN30._SvaS0J-geH725suru-0Gd0S53QuJ1Rd2Sevtg5Bg1E'
);

/* ── constants ──────────────────────────────────── */
const SOURCES     = ['User Interview','Support Ticket','Survey','App Review','Other'];
const CATEGORIES  = ['UX','Performance','Feature Request','Bug','Other'];
const SENTIMENTS  = ['Positive','Negative','Neutral'];
const STATUSES    = ['open','inprogress','addressed'];

const SENTIMENT_STRIPE = { Positive: 'card-pos', Negative: 'card-neg', Neutral: 'card-neu' };
const SENTIMENT_BADGE  = { Positive: 'badge-pos', Negative: 'badge-neg', Neutral: 'badge-neu' };
const STATUS_BADGE     = { open: 'badge-open', inprogress: 'badge-inprogress', addressed: 'badge-addressed' };
const STATUS_LABEL     = { open: 'Open', inprogress: 'In Progress', addressed: 'Addressed' };

function fmtDate(iso) {
  if (!iso) return '';
  return new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

function rowToItem(r) {
  return { id: r.id, createdAt: r.created_at, userId: r.user_id,
           source: r.source, category: r.category, sentiment: r.sentiment,
           content: r.content, status: r.status || 'open' };
}

/* ── AuthForm ────────────────────────────────────── */
function AuthForm() {
  const [mode, setMode]       = React.useState('login');
  const [email, setEmail]     = React.useState('');
  const [pass, setPass]       = React.useState('');
  const [loading, setLoading] = React.useState(false);
  const [error, setError]     = React.useState('');

  async function submit(e) {
    e.preventDefault(); setError(''); setLoading(true);
    const fn = mode === 'login' ? sb.auth.signInWithPassword : sb.auth.signUp;
    const { error: err } = await (mode === 'login'
      ? sb.auth.signInWithPassword({ email, password: pass })
      : sb.auth.signUp({ email, password: pass }));
    if (err) setError(err.message);
    setLoading(false);
  }

  return (
    <div className="min-h-screen flex items-center justify-center px-4">
      <div className="auth-in w-full max-w-sm">
        <div className="mb-8 text-center">
          <h1 className="font-serif text-4xl" style={{color:'var(--text)'}}>
            Pulse
          </h1>
          <p className="font-mono text-xs mt-2" style={{color:'var(--muted)'}}>
            {mode === 'login' ? 'sign in to your workspace' : 'create a new workspace'}
          </p>
        </div>

        <div style={{background:'var(--surface)', border:'1px solid var(--border-hi)', borderRadius:'10px', padding:'28px 28px 24px'}}>
          {error && (
            <div className="mb-5 font-mono text-xs px-3 py-2.5 rounded" style={{background:'rgba(248,81,73,.1)', color:'var(--neg)', border:'1px solid rgba(248,81,73,.2)'}}>
              {error}
            </div>
          )}
          <form onSubmit={submit} className="flex flex-col gap-4">
            <div className="flex flex-col gap-1.5">
              <label className="font-mono text-xs" style={{color:'var(--muted)'}}>Email</label>
              <input type="email" value={email} onChange={e=>setEmail(e.target.value)} required
                placeholder="you@company.com" className="ctrl" />
            </div>
            <div className="flex flex-col gap-1.5">
              <label className="font-mono text-xs" style={{color:'var(--muted)'}}>Password</label>
              <input type="password" value={pass} onChange={e=>setPass(e.target.value)} required
                placeholder="••••••••" minLength={6} className="ctrl" />
            </div>
            <button type="submit" disabled={loading} className="btn-primary mt-1">
              {loading ? 'Please wait…' : mode === 'login' ? 'Sign In' : 'Sign Up'}
            </button>
          </form>
        </div>

        <p className="font-mono text-xs text-center mt-5" style={{color:'var(--muted)'}}>
          {mode === 'login' ? "Don't have an account? " : 'Already have an account? '}
          <button onClick={() => { setMode(mode==='login'?'signup':'login'); setError(''); }}
            style={{color:'#58a6ff', background:'none', border:'none', cursor:'pointer', textDecoration:'underline', font:'inherit'}}>
            {mode === 'login' ? 'Sign up' : 'Sign in'}
          </button>
        </p>
      </div>
    </div>
  );
}

/* ── FeedbackForm ────────────────────────────────── */
function FeedbackForm({ onAdd }) {
  const [content,   setContent]   = React.useState('');
  const [source,    setSource]    = React.useState(SOURCES[0]);
  const [category,  setCategory]  = React.useState(CATEGORIES[0]);
  const [sentiment, setSentiment] = React.useState(SENTIMENTS[2]);
  const [loading,   setLoading]   = React.useState(false);
  const [open,      setOpen]      = React.useState(false);

  async function submit(e) {
    e.preventDefault();
    if (!content.trim()) return;
    setLoading(true);
    await onAdd({ content: content.trim(), source, category, sentiment });
    setContent(''); setSource(SOURCES[0]); setCategory(CATEGORIES[0]); setSentiment(SENTIMENTS[2]);
    setLoading(false);
    setOpen(false);
  }

  if (!open) {
    return (
      <button onClick={() => setOpen(true)} className="btn-primary flex items-center gap-2 text-sm">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <line x1="7" y1="2" x2="7" y2="12" stroke="currentColor" strokeWidth="1.8" strokeLinecap="round"/>
          <line x1="2" y1="7" x2="12" y2="7" stroke="currentColor" strokeWidth="1.8" strokeLinecap="round"/>
        </svg>
        Add Feedback
      </button>
    );
  }

  const selClass = "ctrl pr-8 appearance-none cursor-pointer";

  return (
    <form onSubmit={submit} className="fade-up" style={{
      background: 'var(--surface)', border: '1px solid var(--border-hi)',
      borderRadius: '10px', padding: '20px 20px 16px'
    }}>
      <div className="flex items-center justify-between mb-4">
        <span className="font-sans font-600 text-sm" style={{color:'var(--text)'}}>New Feedback</span>
        <button type="button" onClick={() => setOpen(false)}
          style={{background:'none', border:'none', cursor:'pointer', color:'var(--muted)', fontSize:'18px', lineHeight:1, padding:'0 4px'}}>×</button>
      </div>

      <div className="flex flex-col gap-3">
        <textarea
          value={content}
          onChange={e => setContent(e.target.value)}
          placeholder="Describe the feedback…"
          className="ctrl"
          required
        />

        <div className="grid grid-cols-3 gap-2">
          {[
            [source,    setSource,    SOURCES,    'Source'],
            [category,  setCategory,  CATEGORIES, 'Category'],
            [sentiment, setSentiment, SENTIMENTS, 'Sentiment'],
          ].map(([val, set, opts, label]) => (
            <div key={label} className="flex flex-col gap-1">
              <label className="font-mono text-[10px]" style={{color:'var(--muted)'}}>{label}</label>
              <div className="relative">
                <select value={val} onChange={e => set(e.target.value)} className={selClass}>
                  {opts.map(o => <option key={o} value={o}>{o}</option>)}
                </select>
                <svg className="pointer-events-none absolute right-2.5 top-1/2 -translate-y-1/2" width="10" height="10" viewBox="0 0 10 10" fill="none">
                  <path d="M2 3.5L5 6.5L8 3.5" stroke="#7d8590" strokeWidth="1.4" strokeLinecap="round" strokeLinejoin="round"/>
                </svg>
              </div>
            </div>
          ))}
        </div>

        <div className="flex justify-end gap-2 mt-1">
          <button type="button" onClick={() => setOpen(false)} className="btn-ghost">Cancel</button>
          <button type="submit" disabled={loading || !content.trim()} className="btn-primary text-sm">
            {loading ? 'Adding…' : 'Add Feedback'}
          </button>
        </div>
      </div>
    </form>
  );
}

/* ── FeedbackCard ────────────────────────────────── */
function FeedbackCard({ item, onDelete, onStatusChange }) {
  const [deleting, setDeleting] = React.useState(false);

  async function handleDelete() {
    setDeleting(true);
    await onDelete(item.id);
  }

  const stripe = SENTIMENT_STRIPE[item.sentiment] || 'card-neu';
  const sentBadge = SENTIMENT_BADGE[item.sentiment] || 'badge-neu';
  const statBadge = STATUS_BADGE[item.status] || 'badge-open';

  return (
    <div className={`fade-up ${stripe}`} style={{
      background: 'var(--surface)',
      border: '1px solid var(--border)',
      borderLeft: undefined, /* handled by card-* class */
      borderRadius: '8px',
      padding: '14px 16px',
      opacity: deleting ? 0.4 : 1,
      transition: 'opacity .2s',
    }}>
      {/* Top row */}
      <div className="flex items-start justify-between gap-3 mb-3">
        <p className="font-sans text-sm leading-relaxed flex-1" style={{color:'var(--text)', wordBreak:'break-word'}}>
          {item.content}
        </p>
        <button onClick={handleDelete} disabled={deleting} className="btn-ghost shrink-0 mt-0.5" title="Delete">
          <svg width="11" height="11" viewBox="0 0 12 12" fill="none">
            <path d="M1 1l10 10M11 1L1 11" stroke="currentColor" strokeWidth="1.6" strokeLinecap="round"/>
          </svg>
        </button>
      </div>

      {/* Badge row */}
      <div className="flex flex-wrap items-center gap-1.5">
        <span className={`badge ${sentBadge}`}>{item.sentiment}</span>
        <span className={`badge badge-category`}>{item.category}</span>
        <span className={`badge badge-source`}>{item.source}</span>

        {/* Status select */}
        <div className="relative ml-auto">
          <select
            value={item.status}
            onChange={e => onStatusChange(item.id, e.target.value)}
            className={`badge ${statBadge} appearance-none cursor-pointer pr-4`}
            style={{background:'inherit', border:'inherit', fontFamily:'inherit'}}
          >
            {STATUSES.map(s => <option key={s} value={s}>{STATUS_LABEL[s]}</option>)}
          </select>
          <svg className="pointer-events-none absolute right-1 top-1/2 -translate-y-1/2" width="8" height="8" viewBox="0 0 10 10" fill="none">
            <path d="M2 3.5L5 6.5L8 3.5" stroke="currentColor" strokeWidth="1.4" strokeLinecap="round" strokeLinejoin="round"/>
          </svg>
        </div>
      </div>

      {/* Date */}
      <p className="font-mono text-[10px] mt-2.5" style={{color:'var(--muted)'}}>
        {fmtDate(item.createdAt)}
      </p>
    </div>
  );
}

/* ── FeedbackTracker ─────────────────────────────── */
function FeedbackTracker({ user }) {
  const [items,   setItems]   = React.useState([]);
  const [loading, setLoading] = React.useState(true);
  const [error,   setError]   = React.useState('');
  const [filter,  setFilter]  = React.useState('all'); // sentiment filter

  const errTimer = React.useRef(null);
  function showError(msg) {
    setError(msg);
    clearTimeout(errTimer.current);
    errTimer.current = setTimeout(() => setError(''), 4000);
  }

  React.useEffect(() => {
    (async () => {
      const { data, error } = await sb.from('feedback').select('*').order('created_at', { ascending: false });
      if (error) showError('Failed to load: ' + error.message);
      else setItems(data.map(rowToItem));
      setLoading(false);
    })();
  }, []);

  async function handleAdd(fields) {
    const { data: { user: u } } = await sb.auth.getUser();
    const payload = { ...fields, status: 'open', user_id: u?.id };
    const { data, error } = await sb.from('feedback').insert(payload).select().single();
    if (error) { showError('Failed to add: ' + error.message); return; }
    setItems(prev => [rowToItem(data), ...prev]);
  }

  async function handleDelete(id) {
    setItems(prev => prev.filter(i => i.id !== id));
    const { error } = await sb.from('feedback').delete().eq('id', id);
    if (error) {
      showError('Failed to delete: ' + error.message);
      // re-fetch to restore
      const { data } = await sb.from('feedback').select('*').order('created_at', { ascending: false });
      if (data) setItems(data.map(rowToItem));
    }
  }

  async function handleStatusChange(id, status) {
    setItems(prev => prev.map(i => i.id === id ? { ...i, status } : i));
    const { error } = await sb.from('feedback').update({ status }).eq('id', id);
    if (error) showError('Failed to update status: ' + error.message);
  }

  async function handleLogout() { await sb.auth.signOut(); }

  const displayed = filter === 'all' ? items : items.filter(i => i.sentiment === filter);

  // stats
  const pos = items.filter(i => i.sentiment === 'Positive').length;
  const neg = items.filter(i => i.sentiment === 'Negative').length;
  const neu = items.filter(i => i.sentiment === 'Neutral').length;

  return (
    <div style={{minHeight:'100vh', maxWidth:'780px', margin:'0 auto', padding:'40px 24px 80px'}}>

      {/* Error bar */}
      {error && (
        <div className="mb-6 font-mono text-xs px-4 py-3 rounded-lg flex items-center justify-between fade-up"
          style={{background:'rgba(248,81,73,.1)', color:'var(--neg)', border:'1px solid rgba(248,81,73,.2)'}}>
          <span>{error}</span>
          <button onClick={() => setError('')} style={{background:'none',border:'none',cursor:'pointer',color:'inherit',fontSize:'16px',lineHeight:1}}>×</button>
        </div>
      )}

      {/* Header */}
      <div className="flex items-center justify-between mb-8">
        <div>
          <h1 className="font-serif text-3xl" style={{color:'var(--text)'}}>Pulse</h1>
          <p className="font-mono text-xs mt-0.5" style={{color:'var(--muted)'}}>feedback tracker</p>
        </div>
        <div className="flex items-center gap-3">
          <span className="font-mono text-xs hidden sm:block" style={{color:'var(--muted)', maxWidth:180, overflow:'hidden', textOverflow:'ellipsis', whiteSpace:'nowrap'}}>
            {user.email}
          </span>
          <button onClick={handleLogout} className="btn-ghost">Sign out</button>
        </div>
      </div>

      {/* Stats row */}
      {!loading && items.length > 0 && (
        <div className="grid grid-cols-3 gap-3 mb-8 fade-up">
          {[
            { label: 'Positive', count: pos, color: 'var(--pos)', bg: 'rgba(57,211,83,.07)' },
            { label: 'Negative', count: neg, color: 'var(--neg)', bg: 'rgba(248,81,73,.07)' },
            { label: 'Neutral',  count: neu, color: 'var(--neu)', bg: 'rgba(88,166,255,.07)' },
          ].map(s => (
            <div key={s.label} style={{background: s.bg, border:`1px solid ${s.color}22`, borderRadius:'8px', padding:'12px 16px'}}>
              <p className="font-mono text-xl font-500" style={{color: s.color}}>{s.count}</p>
              <p className="font-mono text-[10px] mt-0.5" style={{color:'var(--muted)'}}>{s.label}</p>
            </div>
          ))}
        </div>
      )}

      {/* Toolbar */}
      <div className="flex items-center justify-between gap-4 mb-5 flex-wrap">
        {/* Filter pills */}
        <div className="flex items-center gap-2 flex-wrap">
          {['all', ...SENTIMENTS].map(f => (
            <button key={f} onClick={() => setFilter(f)}
              className={`pill${filter === f ? ' active' : ''}`}>
              {f === 'all' ? 'All' : f}
            </button>
          ))}
        </div>
        <FeedbackForm onAdd={handleAdd} />
      </div>

      {/* List */}
      {loading ? (
        <div className="flex flex-col gap-3">
          {[1,2,3].map(n => (
            <div key={n} style={{background:'var(--surface)', border:'1px solid var(--border)', borderRadius:'8px', padding:'16px'}}>
              <div className="skel h-4 mb-3" style={{width:`${60+n*10}%`}} />
              <div className="skel h-3" style={{width:'40%'}} />
            </div>
          ))}
        </div>
      ) : displayed.length === 0 ? (
        <div className="text-center py-20 fade-up">
          <p className="font-serif text-2xl italic mb-2" style={{color:'var(--muted)'}}>
            {filter === 'all' ? 'No feedback yet' : `No ${filter.toLowerCase()} feedback`}
          </p>
          <p className="font-mono text-xs" style={{color:'var(--muted)', opacity:.6}}>
            {filter === 'all' ? 'Add your first item above.' : 'Try a different filter.'}
          </p>
        </div>
      ) : (
        <div className="flex flex-col gap-3">
          {displayed.map(item => (
            <FeedbackCard
              key={item.id}
              item={item}
              onDelete={handleDelete}
              onStatusChange={handleStatusChange}
            />
          ))}
        </div>
      )}
    </div>
  );
}

/* ── App ─────────────────────────────────────────── */
function App() {
  const [user, setUser] = React.useState(null);

  React.useEffect(() => {
    sb.auth.getSession().then(({ data: { session } }) => setUser(session?.user ?? false));
    const { data: { subscription } } = sb.auth.onAuthStateChange((_e, session) => {
      setUser(session?.user ?? false);
    });
    return () => subscription.unsubscribe();
  }, []);

  if (user === null) return (
    <div className="min-h-screen flex items-center justify-center">
      <p className="font-mono text-xs" style={{color:'var(--muted)'}}>Loading…</p>
    </div>
  );

  if (user === false) return <AuthForm />;
  return <FeedbackTracker user={user} />;
}

ReactDOM.createRoot(document.getElementById('root')).render(<App />);
</script>
</body>
</html>
